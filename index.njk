---

<section class="hero wrap">
  <a href="https://hopeforamericans.net" class="hfa-eyebrow" target="_blank" rel="noopener">
    <span class="hfa-mark"><svg viewBox="0 0 100 100" fill="none" stroke="white" stroke-width="5" stroke-linecap="round" aria-hidden="true"><path d="M40 34Q40 24 50 24Q60 24 60 34L60 78"/></svg></span>
    <span>A Hope for Americans project</span>
  </a>
  <h1>The Constitution<span class="dot">.</span></h1>
  <p class="lede">{{ site.tagline }}</p>
  <p class="sublede">
    The full text. A plain-English version. Short cards for situations where it matters.
    Free. No accounts. No ads.
  </p>
</section>

<section class="hero-cta wrap">
  <a class="cta primary" href="/preamble/">Start with the Preamble</a>
  <a class="cta secondary" href="/situations/">I need a quick reference</a>
</section>

<section id="situations-preview" class="wrap">
  <h2>Situations</h2>
  <p>Pocket cards for moments when knowing your rights matters.</p>
  <ul class="card-list">
    {% for sit in collections.situations %}
    <li class="card">
      <a href="/situations/{{ sit.data.slug }}/">
        <h3>{{ sit.data.title }}</h3>
        <p>{{ sit.data.summary }}</p>
      </a>
    </li>
    {% endfor %}
  </ul>
</section>

<section id="amendments" class="wrap">
  <h2>Amendments</h2>
  <p>The 27 changes ratified to the Constitution since 1791.</p>
  <ol class="amendment-grid">
    {% for amd in collections.amendments %}
    <li>
      <a href="/amendments/{{ amd.data.number }}/">
        <span class="num">{{ amd.data.number | ordinal }}</span>
        <span class="title">{{ amd.data.title }}</span>
      </a>
    </li>
    {% endfor %}
  </ol>
</section>

<section id="articles" class="wrap">
  <h2>Articles</h2>
  <p>The seven articles of the original Constitution, ratified 1789.</p>
  <ol class="article-list">
    {% for art in collections.articles %}
    <li>
      <a href="/articles/{{ art.data.number }}/">
        <span class="num">Article {{ art.data.number }}</span>
        <span class="title">{{ art.data.title }}</span>
      </a>
    </li>
    {% endfor %}
  </ol>
</section>

<section id="declaration" class="wrap">
  <h2>The Declaration of Independence</h2>
  <p>Not part of the Constitution. The founding statement that the Constitution was later written to put into practice.</p>
  <p><a class="cta secondary" href="/declaration/">Read the Declaration</a></p>
</section>
