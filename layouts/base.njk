<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}{{ title or site.title }}{% endblock %}</title>
<meta name="description" content="{% block description %}{{ description or site.tagline }}{% endblock %}">
<link rel="stylesheet" href="/css/site.css">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<meta name="theme-color" content="#F7F1E3">
{% block head_extra %}{% endblock %}
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>

<header class="site-header">
  <div class="wrap">
    <a class="wordmark" href="/">freeconstitution<span class="dot">.</span>org</a>
    <nav class="primary-nav" aria-label="Primary">
      <a href="/preamble/">Preamble</a>
      <a href="/#articles">Articles</a>
      <a href="/#amendments">Amendments</a>
      <a href="/situations/">Situations</a>
      <a href="/about/">About</a>
    </nav>
    <button class="prefs-toggle" id="prefs-toggle" aria-expanded="false" aria-controls="prefs-panel">
      Reading
    </button>
  </div>
</header>

<aside id="prefs-panel" class="prefs-panel" hidden>
  <div class="wrap">
    <h2>Reading preferences</h2>
    <div class="pref">
      <label for="pref-size">Text size</label>
      <input type="range" id="pref-size" min="14" max="22" step="1" value="17">
    </div>
    <div class="pref">
      <label for="pref-spacing">Line spacing</label>
      <input type="range" id="pref-spacing" min="1.4" max="2.0" step="0.1" value="1.6">
    </div>
    <div class="pref">
      <label for="pref-font">Font</label>
      <select id="pref-font">
        <option value="default">Default (serif)</option>
        <option value="sans">Sans-serif</option>
        <option value="dyslexic">OpenDyslexic</option>
      </select>
    </div>
    <div class="pref">
      <label for="pref-theme">Theme</label>
      <select id="pref-theme">
        <option value="light">Light</option>
        <option value="dark">Dark</option>
      </select>
    </div>
    <div class="pref">
      <label>
        <input type="checkbox" id="pref-italics" checked>
        Show italics
      </label>
    </div>
    <button class="prefs-reset" id="prefs-reset">Reset to default</button>
  </div>
</aside>

<main id="main">
  {% block main %}{{ content | safe }}{% endblock %}
</main>

<footer class="site-footer">
  <div class="wrap">
    <p>{{ site.tagline }}</p>
    <nav aria-label="Footer">
      <a href="/about/">About</a>
      <a href="/sources/">Sources</a>
    </nav>
    <p class="meta">
      Verbatim text from the National Archives. Plain-English layer published under
      <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>.
      No accounts. No ads. No tracking beyond anonymous server logs.
    </p>
    <p class="meta">Last built {{ site.buildDate }}.</p>
  </div>
</footer>

<script src="/js/prefs.js" defer></script>
{% block scripts %}{% endblock %}
</body>
</html>
