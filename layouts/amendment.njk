---
layout: base.njk
---
{% set s = content | sections %}
<article class="amendment">
  <header class="amendment-header wrap">
    <p class="eyebrow">
      {% if part_of == "bill-of-rights" %}Bill of Rights ·{% endif %}
      {{ number | ordinal }} Amendment
    </p>
    <h1>{{ title }}</h1>
    <p class="ratified">Ratified {{ ratified | formatDate }}</p>
  </header>

  {% if s.verbatim %}
  <section class="layer verbatim wrap" aria-labelledby="verbatim">
    <h2 id="verbatim">Verbatim</h2>
    <p class="layer-note">Exact text as ratified.</p>
    {{ s.verbatim | safe }}
  </section>
  {% endif %}

  {% if s.plain_english %}
  <section class="layer plain wrap" aria-labelledby="plain">
    <h2 id="plain">Plain English</h2>
    <p class="layer-note">A translation that drops archaic words but keeps the meaning, including the parts courts still argue about.</p>
    {{ s.plain_english | safe }}
  </section>
  {% endif %}

  {% if s.what_this_means_for_you %}
  <section class="layer practical wrap" aria-labelledby="practical">
    <h2 id="practical">What this means for you</h2>
    {{ s.what_this_means_for_you | safe }}
  </section>
  {% endif %}

  {% if s.what_this_means_for_you_at_school %}
  <section class="layer practical wrap" aria-labelledby="at-school">
    <h2 id="at-school">What this means for you — at school</h2>
    {{ s.what_this_means_for_you_at_school | safe }}
  </section>
  {% endif %}

  {% if s.about %}
  <section class="layer about wrap" aria-labelledby="about">
    <h2 id="about">About</h2>
    {{ s.about | safe }}
  </section>
  {% endif %}

  {% if related_situations %}
  <section class="related wrap">
    <h2>Related situations</h2>
    <ul class="situation-list">
      {% for slug in related_situations %}
        {% for sit in collections.situations %}
          {% if sit.data.slug == slug %}
          <li><a href="/situations/{{ sit.data.slug }}/">{{ sit.data.title }}</a></li>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <nav class="amendment-nav wrap" aria-label="Amendment navigation">
    {% if number > 1 %}
      <a class="prev" href="/amendments/{{ number - 1 }}/">← {{ (number - 1) | ordinal }} Amendment</a>
    {% endif %}
    {% if number < 27 %}
      <a class="next" href="/amendments/{{ number + 1 }}/">{{ (number + 1) | ordinal }} Amendment →</a>
    {% endif %}
  </nav>

  <footer class="review-footer wrap">
    <p class="review-status">
      Verbatim text:
      {% if review and review.verbatim and review.verbatim.status == "verified" %}
        verified against the National Archives on {{ review.verbatim.date | formatDate }}.
      {% else %}
        pending verification.
      {% endif %}
    </p>
    <p class="review-status">
      Plain-English review:
      {% if review and review.plain_english and review.plain_english.status == "verified" %}
        reviewed by {{ review.plain_english.by }} on {{ review.plain_english.date | formatDate }}.
      {% else %}
        pending review.
      {% endif %}
    </p>
    <p class="source-link">
      Source: <a href="{{ source_url }}" rel="external">National Archives</a>
      (retrieved {{ source_retrieved | formatDate }}).
    </p>
  </footer>
</article>
